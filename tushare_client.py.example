"""
Tushare 数据接口初始化模块（模板）。
使用方法：
    1. 复制此文件为 tushare_client.py
    2. 在 .env 中设置 TUSHARE_TOKEN 和 TUSHARE_HOST
    3. 运行: from tushare_client import get_pro
"""
import os
import tushare as ts

# 清除代理（避免干扰国内行情接口）
for _k in ("HTTP_PROXY", "HTTPS_PROXY", "ALL_PROXY",
           "http_proxy", "https_proxy", "all_proxy"):
    os.environ.pop(_k, None)
os.environ["NO_PROXY"] = "*"

# 从环境变量读取（生产环境通过 .env 配置）
TOKEN = os.getenv("TUSHARE_TOKEN", "your_token_here")
TS_HOST = os.getenv("TUSHARE_HOST", "http://api.tushare.pro")


def get_pro() -> ts.pro_api:
    """返回已配置的 Tushare pro_api 实例。"""
    pro = ts.pro_api(TOKEN)
    pro._DataApi__http_url = TS_HOST
    return pro


def get_pro_bar(ts_code: str, **kwargs):
    """获取日线/周线/月线等行情数据。"""
    pro = get_pro()
    import pandas as pd
    return ts.pro_bar(api=pro, ts_code=ts_code, **kwargs)


if __name__ == "__main__":
    pro = get_pro()
    # 测试连接
    df = pro.index_basic(limit=3)
    print("索引基础信息:")
    print(df)
    df2 = ts.pro_bar(api=pro, ts_code="000001.SZ", limit=3)
    print("\n平安银行日线:")
    print(df2)
