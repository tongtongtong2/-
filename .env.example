# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=stock_recommendation

# Flask Configuration
SECRET_KEY=your-secret-key-here
DEBUG=True

# Stock Selection Parameters
TOP_N_STOCKS=10
MIN_VOLUME=100000000

# Trading Parameters
TAKE_PROFIT=0.10
STOP_LOSS=-0.05
MAX_HOLD_DAYS=20

# Scheduler Times (24-hour format)
SELECTION_TIME=15:30
UPDATE_TIME=15:35
STATISTICS_TIME=15:40

# Logging Configuration
LOG_DIR=logs
LOG_FILE=app.log
LOG_LEVEL=INFO
