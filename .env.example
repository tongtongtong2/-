# 数据库配置（必填）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=stock_recommendation

# Flask 配置
SECRET_KEY=change-this-to-a-random-string
DEBUG=True

# 选股参数
TOP_N_STOCKS=10
MIN_VOLUME=100000000

# 交易参数（回测优化后）
TAKE_PROFIT=0.10
STOP_LOSS=-0.05
MAX_HOLD_DAYS=30

# 市场过滤（回测验证：开启后收益提升2.7倍）
MARKET_FILTER=True
INDEX_MA_PERIOD=60
MAX_PER_SECTOR=2

# 调度时间（24小时制）
SELECTION_TIME=15:30
OPEN_FILL_TIME=09:35
UPDATE_TIME=15:35
STATISTICS_TIME=15:40

# 日志
LOG_DIR=logs
LOG_FILE=app.log
LOG_LEVEL=INFO
# Tushare 数据服务配置（私有部署）
TUSHARE_TOKEN=your_token_here
TUSHARE_HOST=http://api.tushare.pro
